    {
      "modifiers": [
        "Alt"
      ],
      "key": "1"
    }
  ],
  "obsidian-footnotes:insert-autonumbered-footnote": [
    {
      "modifiers": [
        "Ctrl"
      ],
      "key": "0"
    }
  ],
  "obsidian-footnotes:insert-named-footnote": [
    {
      "modifiers": [
        "Ctrl"
      ],
      "key": "-"
    }
  ]
}